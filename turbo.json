{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "ADMIN_PASSWORD_HASH",
        "ADMIN_SESSION_SECRET",
        "BLOB_READ_WRITE_TOKEN",
        "BLOB_STORE_ID",
        "BLOB_WEBHOOK_PUBLIC_KEY"
      ],
      "passThroughEnv": ["VERCEL_OIDC_TOKEN"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "!.next/dev/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
